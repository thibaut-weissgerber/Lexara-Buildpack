#!/usr/bin/env bash
set -euo pipefail

BUILD_DIR="$1"
CACHE_DIR="$2"
ENV_DIR="$3"

INSTALL_DIR="$BUILD_DIR/vendor/bin"

mkdir -p "$BUILD_DIR/.profile.d"
mkdir -p "$INSTALL_DIR"

echo "Installing tools into $INSTALL_DIR"

# enry via Go
if command -v go >/dev/null 2>&1; then
  GOBIN="$INSTALL_DIR" go install github.com/go-enry/go-enry/v2/cmd/enry@v2.9.1
else
  echo "go is required to install enry"
  exit 1
fi

# trivy
curl -fsSL \
  https://github.com/aquasecurity/trivy/releases/download/v0.51.2/trivy_0.51.2_Linux-64bit.tar.gz \
  -o /tmp/trivy.tar.gz
tar -xzf /tmp/trivy.tar.gz -C /tmp
cp /tmp/trivy "$INSTALL_DIR/trivy"
chmod +x "$INSTALL_DIR/trivy"

# semgrep
python3 -m pip install --no-cache-dir semgrep
if command -v semgrep >/dev/null 2>&1; then
  cp "$(command -v semgrep)" "$INSTALL_DIR/semgrep"
  chmod +x "$INSTALL_DIR/semgrep"
else
  echo "semgrep install failed"
  exit 1
fi

cat > "$BUILD_DIR/.profile.d/custom-tools.sh" <<'EOF'
export PATH="$HOME/vendor/bin:$PATH"
EOF

echo "Done."
