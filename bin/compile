#!/usr/bin/env bash
set -euo pipefail

readonly TRIVY_VERSION="0.69.3"

BUILD_DIR="$1"
CACHE_DIR="$2"
ENV_DIR="$3"

INSTALL_DIR="$BUILD_DIR/vendor/bin"

mkdir -p "$BUILD_DIR/.profile.d"
mkdir -p "$INSTALL_DIR"

echo "Installing tools into $INSTALL_DIR"

# enry
GOBIN="$INSTALL_DIR" GOFLAGS='' go install github.com/go-enry/enry@latest

# trivy
curl -sfL https://raw.githubusercontent.com/aquasecurity/trivy/main/contrib/install.sh | sh -s -- -b "${INSTALL_DIR}" "v${TRIVY_VERSION}"
chmod +x "$INSTALL_DIR/trivy"

# semgrep
curl https://bootstrap.pypa.io/get-pip.py > get-pip.py
python3 get-pip.py --break-system-packages
python3 -m pip install --no-cache-dir semgrep --break-system-packages
cp "$HOME/.local/bin/pysemgrep" "$INSTALL_DIR/pysemgrep"
cp "$HOME/.local/bin/semgrep" "$INSTALL_DIR/semgrep"
chmod +x "$INSTALL_DIR/semgrep"

cat > "$BUILD_DIR/.profile.d/custom-tools.sh" <<'EOF'
export PATH="$HOME/vendor/bin:$PATH"
EOF

echo "Done."
